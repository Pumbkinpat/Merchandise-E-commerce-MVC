@using EcommerceApp1.Controllers
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Online merchandise store</title>
    
    @*
    <!-- Compiled css with bootstrap style packed in -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true"/>
	<script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    <!-- Bootstrap swiper js CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css" />
    <!-- Bootstrap icon CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>
    *@
    
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    
</head>
<body class="static">
<!-- Navigation bar -->
<header class="sticky top-0 z-50 bg-base-100">
    <!-- Navbar Start -->
    <div class="navbar shadow-sm">
	    <div class="navbar-start">
		    <a class="btn btn-ghost text-xl">Merchandise Store</a>
	    </div>
	    
	    <div class="navbar-center">
		    <ul class="menu menu-horizontal px-1">
			    <li><a href="/Home">Home</a></li>
			    <li><a href="/Products/Index">Products</a></li>
			    <li>
				    <details class="">
					    <summary>Pages</summary>
					    <ul class="bg-base-100 rounded-t-none p-2">
						    <li class="nowrap"><a href="#">Shopping Cart</a></li>
						    <li><a href="#">Checkout</a></li>
					    </ul>
				    </details>
			    </li>
			    <li><a href="/Home/Contact">Contact</a></li>
		    </ul>
	    </div>
	    
	    <div class="navbar-end gap-2">
		    <form method="get" asp-controller="Products" asp-action="Search">
			    <label class="input">
				    <svg class="inline h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
					    <g
						    stroke-linejoin="round"
						    stroke-linecap="round"
						    stroke-width="2.5"
						    fill="none"
						    stroke="currentColor">
						    <circle cx="11" cy="11" r="8"></circle>
						    <path d="m21 21-4.3-4.3"></path>
					    </g>
				    </svg>
				    <input name="searchString" placeholder="Search" type="search" value="@(ViewBag.Page == "Products" ? @Model.SearchString : "")"/>
			    </label>
		    </form>

		    <div class="dropdown dropdown-end">
			    <script>
				    async function LoadShoppingCart() {

					    const response = await fetch('/ShoppingCart/GetCart');

					    const cartItems = await response.json();

					    const cartContainer = document.getElementById("shopping-cart-items");

					    cartContainer.innerHTML = "";

					    if (cartItems.length === 0) {
						    cartContainer.innerHTML = "<li>Cart is empty</li>";
						    return;
					    }

					    cartItems.forEach(item => {

						    cartContainer.innerHTML += `
				                <li class="list-row justify-items-end">
				                    <div class="text-xs font-semibold uppercase">
				                        ${item.cartItemName}
				                    </div>
				
				                    <div class="join self-end">
				                        <button onclick="" class="join-item btn btn-square btn-ghost">-</button>
				
				                        <span class="join-item text-center self-center mx-2">
				                            ${item.cartItemQuantity}
				                        </span>
				
				                        <button onclick="" class="join-item btn btn-square btn-ghost">+</button>
				                    </div>
				                </li>
            				`;
					    });
				    }
			    </script>
			    <div onclick="LoadShoppingCart()" tabindex="0" role="button" class="btn btn-ghost btn-circle">
				    <div class="indicator">
					    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/> </svg>
					    <span class="badge badge-sm indicator-item">8</span>
				    </div>
			    </div>
			    <div
				    tabindex="0"
				    class="card card-compact dropdown-content bg-base-100 z-1 mt-6 w-100 shadow border-1">
				    <div class="card-body">
					    <ul id="shopping-cart-items" class="list p-0 bg-base-100 rounded-box">
							<!-- Cart Items -->
					    </ul>
					    <div class="card-actions">
						    <button class="btn btn-ghost btn-block">View cart</button>
					    </div>
				    </div>
			    </div>
		    </div>
		    <div class="dropdown dropdown-end">
			    <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
				    <div class="w-10 rounded-full">
					    <img
						    alt="Tailwind CSS Navbar component"
						    src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"/>
				    </div>
			    </div>
			    @await Html.PartialAsync("_LoginPartial")
		    </div>
	    </div>
    </div>
    <!-- Navbar End -->
</header>

<!-- Main page -->
<div class="">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>


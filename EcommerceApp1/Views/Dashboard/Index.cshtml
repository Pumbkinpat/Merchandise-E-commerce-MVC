@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Merch Store</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <style>
        .mono { font-family: 'DM Mono', monospace; }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.92rem;
            letter-spacing: 0.01em;
            transition: background 0.18s, color 0.18s;
            color: #a1a1aa;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: rgba(250,204,21,0.10);
            color: #facc15;
        }
        .sidebar-link .icon {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            font-size: 1rem;
        }
        .sidebar-link.active .icon {
            background: rgba(250,204,21,0.18);
        }

        .table-row-hover:hover {
            background: rgba(250,204,21,0.04) !important;
        }
        .stat-card {
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(8px);
            padding: 20px 24px;
            transition: border-color 0.2s, transform 0.2s;
        }
        .stat-card:hover {
            border-color: rgba(250,204,21,0.3);
            transform: translateY(-2px);
        }
        .badge-cat {
            font-family: 'DM Mono', monospace;
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 6px;
            background: rgba(250,204,21,0.12);
            color: #facc15;
            border: 1px solid rgba(250,204,21,0.2);
        }
        .delete-btn {
            width: 30px; height: 30px;
            border-radius: 8px;
            border: 1px solid rgba(239,68,68,0.25);
            background: rgba(239,68,68,0.07);
            color: #f87171;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.85rem;
            transition: all 0.15s;
            cursor: pointer;
        }
        .delete-btn:hover {
            background: rgba(239,68,68,0.2);
            border-color: rgba(239,68,68,0.5);
        }
        .search-input {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 8px 14px 8px 36px;
            color: #e4e4e7;
            font-size: 0.875rem;
            outline: none;
            transition: border-color 0.2s;
            width: 220px;
            font-family: 'DM Mono', monospace;
        }
        .search-input::placeholder { color: #52525b; }
        .search-input:focus { border-color: rgba(250,204,21,0.4); }

        .add-btn {
            display: inline-flex; align-items: center; gap: 7px;
            background: #facc15;
            color: #18181b;
            font-weight: 700;
            font-size: 0.875rem;
            padding: 9px 18px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s, transform 0.15s;
        }
        .add-btn:hover { background: #fde047; transform: translateY(-1px); }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #52525b; }

        .drawer-side-custom {
            width: 260px;
            background: #111113;
            border-right: 1px solid rgba(255,255,255,0.07);
            display: flex;
            flex-direction: column;
            padding: 28px 16px;
            gap: 6px;
            min-height: 100vh;
        }
    </style>
</head>
<body data-theme="dark" style="background:#0e0e10; color:#e4e4e7; min-height:100vh;">

<div class="flex" style="min-height:100vh;">
    
    <div class="drawer lg:drawer-open" style="width:260px; flex-shrink:0;">
        <input id="my-drawer-3" type="checkbox" class="drawer-toggle"/>
        <div class="drawer-side">
            <label for="my-drawer-3" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="drawer-side-custom">
           
                <div style="padding: 0 6px 20px; border-bottom: 1px solid rgba(255,255,255,0.07); margin-bottom: 12px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="width:34px;height:34px;background:#facc15;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🛍️</div>
                        <div>
                            <div style="font-weight:800;font-size:1rem;letter-spacing:-0.02em;color:#fafafa;">MerchStore</div>
                            <div class="mono" style="font-size:0.65rem;color:#52525b;letter-spacing:0.05em;">ADMIN PANEL</div>
                        </div>
                    </div>
                </div>
                
                <div style="font-size:0.68rem;color:#52525b;letter-spacing:0.12em;font-weight:600;padding: 0 6px 8px;text-transform:uppercase;">Inventory</div>
                <a href="#" class="sidebar-link active">
                    <span class="icon">📦</span> Products
                </a>
                <a asp-controller="Dashboard" asp-action="AddProduct" class="sidebar-link">
                    <span class="icon">➕</span> Add Product
                </a>
                <a asp-controller="Products" asp-action="Index" class="sidebar-link">
                    <span class="icon">🏪</span> Storefront
                </a>

                <div style="margin-top:16px;font-size:0.68rem;color:#52525b;letter-spacing:0.12em;font-weight:600;padding: 0 6px 8px;text-transform:uppercase;">Manage</div>
                <a href="#" class="sidebar-link">
                    <span class="icon">🏷️</span> Categories
                </a>
                <a href="#" class="sidebar-link">
                    <span class="icon">📋</span> Orders
                </a>
                
                <div style="margin-top:auto;padding-top:20px;border-top:1px solid rgba(255,255,255,0.07);">
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 6px;">
                        <img src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                             alt="avatar" style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid #facc15;"/>
                        <div>
                            <div style="font-weight:600;font-size:0.85rem;color:#e4e4e7;">@User.Identity?.Name</div>
                            @if (User.IsInRole("Admin"))
                            {
                                <span style="font-size:0.65rem;background:rgba(250,204,21,0.15);color:#facc15;padding:1px 7px;border-radius:4px;font-family:'DM Mono',monospace;border:1px solid rgba(250,204,21,0.2);">ADMIN</span>
                            }
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
    
    <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
        
        <header style="height:60px; border-bottom:1px solid rgba(255,255,255,0.07); display:flex; align-items:center; padding:0 28px; gap:16px; flex-shrink:0;">
            <label for="my-drawer-3" class="btn btn-ghost btn-sm lg:hidden">☰</label>
            <div style="flex:1;">
                <h1 style="font-size:1.1rem;font-weight:700;color:#fafafa;letter-spacing:-0.02em;">Product Inventory</h1>
            </div>
            <a asp-area="Identity" asp-page="/Account/Manage/Index"
               style="font-size:0.8rem;color:#71717a;text-decoration:none;font-family:'DM Mono',monospace;">
                ⚙ Settings
            </a>
        </header>
        
        <main style="flex:1;overflow-y:auto;padding:28px 32px;">
            
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:32px;">
                <div class="stat-card">
                    <div class="mono" style="font-size:0.7rem;color:#71717a;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">Total Products</div>
                    <div style="font-size:2rem;font-weight:800;color:#fafafa;letter-spacing:-0.03em;">—</div>
                    <div style="font-size:0.75rem;color:#52525b;margin-top:4px;">Active listings</div>
                </div>
                <div class="stat-card">
                    <div class="mono" style="font-size:0.7rem;color:#71717a;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">In Stock</div>
                    <div style="font-size:2rem;font-weight:800;color:#4ade80;letter-spacing:-0.03em;">—</div>
                    <div style="font-size:0.75rem;color:#52525b;margin-top:4px;">Units available</div>
                </div>
                <div class="stat-card">
                    <div class="mono" style="font-size:0.7rem;color:#71717a;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">Categories</div>
                    <div style="font-size:2rem;font-weight:800;color:#a78bfa;letter-spacing:-0.03em;">—</div>
                    <div style="font-size:0.75rem;color:#52525b;margin-top:4px;">Product types</div>
                </div>
                <div class="stat-card">
                    <div class="mono" style="font-size:0.7rem;color:#71717a;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">Low Stock</div>
                    <div style="font-size:2rem;font-weight:800;color:#fb923c;letter-spacing:-0.03em;">—</div>
                    <div style="font-size:0.75rem;color:#52525b;margin-top:4px;">Needs restock</div>
                </div>
            </div>
            
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
                <div style="font-size:0.9rem;font-weight:700;color:#e4e4e7;">All Products</div>
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="position:relative;">
                        <span style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#52525b;font-size:0.85rem;">🔍</span>
                        <input class="search-input" type="text" placeholder="Search products…" id="searchInput" oninput="filterTable()"/>
                    </div>
                    <a asp-controller="Dashboard" asp-action="AddProduct" class="add-btn">
                        <span>＋</span> Add Product
                    </a>
                </div>
            </div>
            
            <div style="border:1px solid rgba(255,255,255,0.07);border-radius:14px;overflow:hidden;">
                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;" id="productTable">
                        <thead>
                            <tr style="border-bottom:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.02);">
                                <th style="padding:12px 16px;text-align:left;">
                                    <input type="checkbox" class="checkbox checkbox-xs" style="border-color:#3f3f46;"/>
                                </th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">ID</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Product</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Description</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Price</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Stock</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Date</th>
                                <th class="mono" style="padding:12px 10px;text-align:left;font-size:0.68rem;color:#71717a;letter-spacing:0.1em;font-weight:500;text-transform:uppercase;">Category</th>
                                <th style="padding:12px 10px;"></th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            @{ List<Product> products = Model; }
                            @foreach (var product in products)
                            {
                                <tr class="table-row-hover" style="border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;">
                                    <td style="padding:12px 16px;">
                                        <input type="checkbox" class="checkbox checkbox-xs" style="border-color:#3f3f46;"/>
                                    </td>
                                    <td class="mono" style="padding:12px 10px;font-size:0.75rem;color:#52525b;">#@product.ProductId</td>
                                    <td style="padding:12px 10px;">
                                        <div style="display:flex;align-items:center;gap:10px;">
                                            <div style="width:36px;height:36px;border-radius:8px;overflow:hidden;flex-shrink:0;border:1px solid rgba(255,255,255,0.08);">
                                                <img src="@product.ImageUrl" alt="@product.Name" style="width:100%;height:100%;object-fit:cover;"/>
                                            </div>
                                            <span style="font-weight:600;font-size:0.875rem;color:#fafafa;">@product.Name</span>
                                        </div>
                                    </td>
                                    <td style="padding:12px 10px;font-size:0.8rem;color:#71717a;max-width:200px;">
                                        <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;">@product.Description</div>
                                    </td>
                                    <td class="mono" style="padding:12px 10px;font-size:0.85rem;font-weight:600;color:#4ade80;">$@product.Price</td>
                                    <td style="padding:12px 10px;">
                                        @if (product.StockQuantity <= 5)
                                        {
                                            <span class="mono" style="font-size:0.75rem;padding:2px 8px;border-radius:6px;background:rgba(251,146,60,0.12);color:#fb923c;border:1px solid rgba(251,146,60,0.2);">@product.StockQuantity low</span>
                                        }
                                        else
                                        {
                                            <span class="mono" style="font-size:0.75rem;padding:2px 8px;border-radius:6px;background:rgba(74,222,128,0.08);color:#4ade80;border:1px solid rgba(74,222,128,0.15);">@product.StockQuantity</span>
                                        }
                                    </td>
                                    <td class="mono" style="padding:12px 10px;font-size:0.75rem;color:#52525b;">@product.DateCreated.ToString("MMM d, yyyy")</td>
                                    <td style="padding:12px 10px;">
                                        <span class="badge-cat">Cat #@product.CategoryId</span>
                                    </td>
                                    <td style="padding:12px 16px;">
                                        <button class="delete-btn" onclick="TriggerDelete(@product.ProductId)" title="Delete product">🗑</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (!products.Any())
                {
                    <div style="padding:60px;text-align:center;">
                        <div style="font-size:2.5rem;margin-bottom:12px;">📦</div>
                        <div style="font-weight:700;font-size:1rem;color:#e4e4e7;margin-bottom:6px;">No products yet</div>
                        <div style="font-size:0.85rem;color:#52525b;">Add your first product to get started.</div>
                    </div>
                }
                
                <div style="padding:10px 16px;border-top:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:space-between;">
                    <span class="mono" style="font-size:0.72rem;color:#52525b;">@products.Count item(s)</span>
                    <span class="mono" style="font-size:0.72rem;color:#52525b;">Page 1 of 1</span>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js" type="text/javascript"></script>
<script>
    function TriggerDelete(productId) {
        if (!confirm('Delete this product?')) return;
        const xhttp = new XMLHttpRequest();
        xhttp.open("DELETE", `/Dashboard/DeleteProduct?productId=${productId}`);
        xhttp.onload = function () { location.reload(); }
        xhttp.send();
    }
    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('#productTableBody tr');
        rows.forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
</script>
</body>
</html>
@{
    ViewData["Title"] = "Checkout";
    Layout = "_Layout";
}

<div class="min-h-screen bg-base-200 py-10 px-4">
    <div class="max-w-5xl mx-auto">

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight">Checkout</h1>
            <p class="text-base-content/60 mt-1">Complete your order</p>
        </div>

        <!-- Steps -->
        <ul class="steps w-full mb-10">
            <li class="step step-primary">Cart</li>
            <li class="step step-primary">Details</li>
            <li class="step">Payment</li>
            <li class="step">Confirm</li>
        </ul>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Shipping form -->
            <div class="lg:col-span-2 card bg-base-100 shadow-sm">
                <div class="card-body gap-5">
                    <h2 class="card-title">Shipping Details</h2>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="form-control">
                            <label class="label"><span class="label-text">First Name</span></label>
                            <input type="text" placeholder="John"
                                   class="input input-bordered w-full" id="first-name"/>
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text">Last Name</span></label>
                            <input type="text" placeholder="Doe"
                                   class="input input-bordered w-full" id="last-name"/>
                        </div>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text">Email</span></label>
                        <input type="email" placeholder="john@example.com"
                               class="input input-bordered w-full" id="email"/>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text">Address</span></label>
                        <input type="text" placeholder="123 Main St"
                               class="input input-bordered w-full" id="address"/>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div class="form-control sm:col-span-1">
                            <label class="label"><span class="label-text">City</span></label>
                            <input type="text" placeholder="City"
                                   class="input input-bordered w-full" id="city"/>
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text">State</span></label>
                            <input type="text" placeholder="State"
                                   class="input input-bordered w-full" id="state"/>
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text">ZIP</span></label>
                            <input type="text" placeholder="00000"
                                   class="input input-bordered w-full" id="zip"/>
                        </div>
                    </div>

                    <div class="divider">Payment</div>

                    <div class="form-control">
                        <label class="label"><span class="label-text">Card Number</span></label>
                        <input type="text" placeholder="•••• •••• •••• ••••"
                               maxlength="19"
                               class="input input-bordered w-full font-mono" id="card-number"/>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="form-control">
                            <label class="label"><span class="label-text">Expiry</span></label>
                            <input type="text" placeholder="MM / YY"
                                   maxlength="7"
                                   class="input input-bordered w-full font-mono" id="expiry"/>
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text">CVV</span></label>
                            <input type="text" placeholder="•••"
                                   maxlength="3"
                                   class="input input-bordered w-full font-mono" id="cvv"/>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order summary -->
            <div class="card bg-base-100 shadow-sm h-fit sticky top-6">
                <div class="card-body gap-4">
                    <h2 class="card-title text-lg">Order Summary</h2>
                    <div class="divider my-0"></div>

                    <ul id="checkout-items" class="flex flex-col gap-2 text-sm"></ul>

                    <div class="divider my-0"></div>

                    <div class="flex flex-col gap-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-base-content/60">Shipping</span>
                            <span class="text-success font-medium">Free</span>
                        </div>
                    </div>

                    <div class="divider my-0"></div>

                    <div class="flex justify-between font-bold">
                        <span>Total</span>
                        <span id="checkout-total">$0.00</span>
                    </div>

                    <button onclick="placeOrder()"
                            class="btn btn-primary btn-block mt-2">
                        Place Order
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    async function loadCheckoutSummary() {
        const res  = await fetch('/ShoppingCart/GetCart');
        const cart = await res.json();

        const list = document.getElementById('checkout-items');
        list.innerHTML = cart.items.map(item => `
            <li class="flex justify-between">
                <span class="truncate max-w-[160px]">${item.cartItemName}
                    <span class="text-base-content/50">×${item.cartItemQuantity}</span>
                </span>
                <span>$${item.subTotal.toFixed(2)}</span>
            </li>
        `).join('');

        document.getElementById('checkout-total').textContent =
            `$${cart.totalPrice.toFixed(2)}`;
    }

    async function placeOrder() {
        const payload = {
            firstName : document.getElementById('first-name').value,
            lastName  : document.getElementById('last-name').value,
            email     : document.getElementById('email').value,
            address   : document.getElementById('address').value,
            city      : document.getElementById('city').value,
            state     : document.getElementById('state').value,
            zip       : document.getElementById('zip').value,
        };

        // Basic validation
        if (Object.values(payload).some(v => !v.trim())) {
            alert('Please fill in all fields.');
            return;
        }

        const btn = document.querySelector('button[onclick="placeOrder()"]');
        btn.classList.add('loading');
        btn.disabled = true;

        const res = await fetch('/ShoppingCart/PlaceOrder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        if (res.ok) {
            const data = await res.json();
            window.location.href = `/ShoppingCart/OrderConfirmation?orderId=${data.orderId}`;
        } else {
            alert('Something went wrong. Please try again.');
            btn.classList.remove('loading');
            btn.disabled = false;
        }
    }

    loadCheckoutSummary();
</script>
}
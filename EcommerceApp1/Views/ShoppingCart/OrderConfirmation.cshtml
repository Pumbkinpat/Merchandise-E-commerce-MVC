@model EcommerceApp1.Models.Order

@{
    ViewData["Title"] = "Order Confirmed";
    Layout = "_Layout";
}

<div class="min-h-screen bg-base-200 py-16 px-4">
    <div class="max-w-2xl mx-auto flex flex-col items-center gap-8">

        <!-- Success icon -->
        <div class="flex flex-col items-center gap-3 text-center">
            <div class="w-20 h-20 rounded-full bg-success/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-success"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h1 class="text-3xl font-bold">Order Confirmed!</h1>
            <p class="text-base-content/60">
                Thank you, <strong>@Model.FirstName</strong>. A confirmation email has been sent to
                <strong>@Model.Email</strong>.
            </p>
            <div class="badge badge-outline badge-lg">Order #@Model.OrderId</div>
        </div>

        <!-- Order summary card -->
        <div class="card bg-base-100 shadow-sm w-full">
            <div class="card-body gap-4">
                <div class="flex justify-between items-center">
                    <h2 class="card-title text-base">Order Summary</h2>
                    <span class="text-sm text-base-content/50">@Model.OrderDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="divider my-0"></div>

                @foreach (var item in Model.OrderItems)
                {
                    <div class="flex justify-between text-sm">
                        <span>@item.Product.Name <span class="text-base-content/50">×@item.Quantity</span></span>
                        <span>$@((item.UnitPrice * item.Quantity).ToString("F2"))</span>
                    </div>
                }

                <div class="divider my-0"></div>

                <div class="flex justify-between font-bold">
                    <span>Total</span>
                    <span>$@Model.TotalPrice.ToString("F2")</span>
                </div>
            </div>
        </div>

        <!-- Shipping address -->
        <div class="card bg-base-100 shadow-sm w-full">
            <div class="card-body">
                <h2 class="card-title text-base">Shipping To</h2>
                <div class="divider my-0"></div>
                <p class="text-sm leading-relaxed">
                    @Model.FirstName @Model.LastName<br/>
                    @Model.Address<br/>
                    @Model.City, @Model.State @Model.Zip
                </p>
            </div>
        </div>

        <a href="/Products/Index" class="btn btn-primary btn-wide">Continue Shopping</a>
    </div>
</div>
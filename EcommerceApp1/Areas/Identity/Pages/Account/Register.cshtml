@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-6">
        
        <div class="text-center">
            <h3 class="text-3xl font-bold tracking-tight">Create an account</h3>
        </div>
        
        <div class="card bg-base-100 shadow-md border border-base-200">
            <div class="card-body gap-4">

                <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-col gap-4">

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Email</legend>
                        <input asp-for="Input.Email"
                               type="email"
                               class="input input-bordered w-full"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="fieldset-label text-error text-xs"></span>
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Password</legend>
                        <input asp-for="Input.Password"
                               type="password"
                               class="input input-bordered w-full"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="fieldset-label text-error text-xs"></span>
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Confirm Password</legend>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="input input-bordered w-full"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="••••••••" />
                        <span asp-validation-for="Input.ConfirmPassword" class="fieldset-label text-error text-xs"></span>
                    </fieldset>

                    <button id="registerSubmit" type="submit" class="btn btn-neutral w-full mt-2">
                        Create account
                    </button>
                </form>

                <div class="divider text-xs text-base-content/40">or</div>

                <div class="text-sm text-center text-base-content/60">
                    <p>
                        Already have an account?
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="link link-primary font-medium">
                            Log in
                        </a>
                    </p>
                </div>

            </div>
        </div>
        
        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="card bg-base-100 shadow-sm border border-base-200">
                <div class="card-body gap-3">
                    <p class="text-sm font-medium text-base-content/60 text-center">Or register with</p>
                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post"
                          class="flex flex-col gap-2">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn btn-outline w-full"
                                    name="provider"
                                    value="@provider.Name"
                                    title="Register using your @provider.DisplayName account">
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
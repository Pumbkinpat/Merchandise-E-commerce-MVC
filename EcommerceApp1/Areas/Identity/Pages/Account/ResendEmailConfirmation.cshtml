@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend email confirmation";
}

<div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-6">

        <div class="text-center">
            <h3 class="text-3xl font-bold tracking-tight">Resend confirmation</h3>
            <p class="mt-2 text-sm text-base-content/60">Enter your email and we'll resend the confirmation link</p>
        </div>

        <div class="card bg-base-100 shadow-md border border-base-200">
            <div class="card-body gap-4">

                <div asp-validation-summary="All" class="text-danger" role="alert"></div>

                <form method="post" class="flex flex-col gap-4">

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Email</legend>
                        <input asp-for="Input.Email"
                               type="email"
                               class="input input-bordered w-full"
                               aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="fieldset-label text-error text-xs"></span>
                    </fieldset>

                    <button type="submit" class="btn btn-neutral w-full mt-2">
                        Resend confirmation email
                    </button>

                </form>

                <div class="text-sm text-center text-base-content/60">
                    <p>
                        Already confirmed?
                        <a asp-page="./Login" class="link link-primary font-medium">Back to log in</a>
                    </p>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-factor authentication (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="space-y-6">

    <div>
        <h3 class="text-xl font-semibold">@ViewData["Title"]</h3>
        <p class="text-sm text-base-content/60">Manage your two-factor authentication settings</p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    @{
        var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
        if (consentFeature?.CanTrack ?? true)
        {
            if (Model.Is2faEnabled)
            {
                if (Model.RecoveryCodesLeft == 0)
                {
                    <div class="alert alert-error text-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                        </svg>
                        <div>
                            <p class="font-semibold">You have no recovery codes left.</p>
                            <p>You must <a asp-page="./GenerateRecoveryCodes" class="link">generate a new set of recovery codes</a> before you can log in with a recovery code.</p>
                        </div>
                    </div>
                }
                else if (Model.RecoveryCodesLeft == 1)
                {
                    <div class="alert alert-error text-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                        </svg>
                        <div>
                            <p class="font-semibold">You have 1 recovery code left.</p>
                            <p>You can <a asp-page="./GenerateRecoveryCodes" class="link">generate a new set of recovery codes</a>.</p>
                        </div>
                    </div>
                }
                else if (Model.RecoveryCodesLeft <= 3)
                {
                    <div class="alert alert-warning text-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                        </svg>
                        <div>
                            <p class="font-semibold">You have @Model.RecoveryCodesLeft recovery codes left.</p>
                            <p>You should <a asp-page="./GenerateRecoveryCodes" class="link">generate a new set of recovery codes</a>.</p>
                        </div>
                    </div>
                }
                
                <div class="card bg-base-100 shadow-md border border-base-200">
                    <div class="card-body gap-3">
                        <h4 class="font-semibold">2FA is enabled</h4>
                        <div class="flex flex-wrap gap-2">
                            @if (Model.IsMachineRemembered)
                            {
                                <form method="post" class="contents">
                                    <button type="submit" class="btn btn-outline btn-sm">Forget this browser</button>
                                </form>
                            }
                            <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline btn-sm">Reset recovery codes</a>
                            <a asp-page="./Disable2fa" class="btn btn-error btn-outline btn-sm">Disable 2FA</a>
                        </div>
                    </div>
                </div>
            }
            
            <div class="card bg-base-100 shadow-md border border-base-200">
                <div class="card-body gap-3">
                    <h4 class="font-semibold">Authenticator app</h4>
                    <p class="text-sm text-base-content/60">
                        Use an authenticator app to generate one-time codes for signing in.
                    </p>
                    <div class="flex flex-wrap gap-2">
                        @if (!Model.HasAuthenticator)
                        {
                            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn badge-neutral btn-sm">
                                Add authenticator app
                            </a>
                        }
                        else
                        {
                            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-outline btn-sm">
                                Set up authenticator app
                            </a>
                            <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="btn btn-outline btn-error btn-sm">
                                Reset authenticator app
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-error text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                </svg>
                <div>
                    <p class="font-semibold">Privacy and cookie policy have not been accepted.</p>
                    <p>You must accept the policy before you can enable two-factor authentication.</p>
                </div>
            </div>
        }
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}